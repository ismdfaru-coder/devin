# Database (PostgreSQL). For local dev you can run Postgres in Docker:
#   docker run -d -e POSTGRES_PASSWORD=devpass -e POSTGRES_DB=blog -p 5432:5432 postgres:16
# or point this at a hosted Postgres (Neon, Supabase, Vercel Postgres).
DATABASE_URL="postgresql://postgres:devpass@localhost:5432/blog?schema=public"

# Site branding
NEXT_PUBLIC_SITE_NAME="InfoThink"
NEXT_PUBLIC_SITE_DESCRIPTION="Read, Learn, Change"
NEXT_PUBLIC_AUTHOR_NAME="The Author"
NEXT_PUBLIC_AUTHOR_BIO="Writer, thinker, and explorer of ideas. Sharing insights on technology, life, and everything in between."
NEXT_PUBLIC_AUTHOR_IMAGE="" # URL to author photo (optional)
NEXT_PUBLIC_SITE_URL="https://devin-zeta.vercel.app"

# Admin (only you). Password is used to log in at /login.
# For production, set ADMIN_PASSWORD_HASH instead (bcrypt hash) and remove ADMIN_PASSWORD.
ADMIN_PASSWORD="admin321"
# ADMIN_PASSWORD_HASH=""

# Secret used to sign the admin session cookie. Change this to a long random string.
AUTH_SECRET="supersecretkey123456789abcdefghijklmnopqrstuvwxyz"

# Email (optional). Get a free key at https://resend.com
# Without these, new-post notifications are logged to the server console instead of emailed.
RESEND_API_KEY=""
EMAIL_FROM="InfoThink <onboarding@resend.dev>"

# Social links (optional)
NEXT_PUBLIC_SOCIAL_X=""
NEXT_PUBLIC_SOCIAL_FACEBOOK=""
NEXT_PUBLIC_SOCIAL_INSTAGRAM=""
NEXT_PUBLIC_SOCIAL_YOUTUBE=""
NEXT_PUBLIC_SOCIAL_LINKEDIN=""

# ============================================
# ADVERTISEMENT SETTINGS (Google AdSense)
# ============================================
# Sign up at https://www.google.com/adsense

# Header Banner Ad (728x90) - Shows below navigation
NEXT_PUBLIC_AD_HEADER_ENABLED="false"
NEXT_PUBLIC_AD_HEADER_CLIENT="" # ca-pub-XXXXXXXX
NEXT_PUBLIC_AD_HEADER_SLOT=""

# In-Article Ad (300x250) - Shows in article content
NEXT_PUBLIC_AD_INARTICLE_ENABLED="false"
NEXT_PUBLIC_AD_INARTICLE_CLIENT="" # ca-pub-XXXXXXXX
NEXT_PUBLIC_AD_INARTICLE_SLOT=""
NEXT_PUBLIC_AD_INARTICLE_AFTER="3" # After which paragraph to show ad

# Footer Banner Ad - Shows above footer
NEXT_PUBLIC_AD_FOOTER_ENABLED="false"
NEXT_PUBLIC_AD_FOOTER_CLIENT="" # ca-pub-XXXXXXXX
NEXT_PUBLIC_AD_FOOTER_SLOT=""
